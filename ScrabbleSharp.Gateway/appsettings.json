{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "https://scrabble-sharp.bisocm.org" ]
  },
  "RateLimiting": {
    "PermitLimit": 30,
    "WindowInMinutes": 1
  },
  "Validation": {
    "MaxRackSize": 7,
    "MaxWildcards": 3,
    "MaxBoardDimension": 40,
    "MaxBandsPerDirection": 4
  }
}